'use client'
import { saveEngineLog } from '@/app/actions/engine'
import { Button } from '@/components/ui/button'
import { Input } from '@/components/ui/input'
import React, { useActionState, useState } from 'react'
import { toast } from 'sonner'



const EngineForm = ({officeId}: {officeId: string}) => {
    // const [state, formAction, isPending] = useActionState(saveEngineLog, null)
    const [error, setError] = useState<string | null>(null)
    const [loading, setLoading] = useState(false);

    const handleSubmit = async (e: React.FormEvent<HTMLFormElement>) => {
      e.preventDefault();

      setError(null);
      setLoading(true);

      const formData = new FormData(e.currentTarget);
      const date = formData.get("date") as string;

      // Helper to get timestamp for comparison
      const getTime = (name: string) => {
        const val = formData.get(name);
        return val ? new Date(`${date}T${val}`).getTime() : null;

      };

      const pOff = getTime("powerOff");
      const eOn = getTime("engineOn");
      const pOn = getTime("powerOn");
      const eOff = getTime("engineOff");

      const ONE_MIN = 60000;

      // 1. validation Logic
      if(pOff && eOn && eOn < pOff + ONE_MIN){
        setError("Engine on must be at lease 1 minute after Power Off.")
        setLoading(false);
        return;
      }
      if(pOn && eOff && eOff < pOn + ONE_MIN){
        setError("Engine Off must be at least 1 minute after Power On.");
        setLoading(false);
        return;
      }

      // 2. Submit to Server Action
      const result = await saveEngineLog({ success: false}, formData);

      if(result.success) {
        toast.success("Log saved successfully");
        (e.target as HTMLFormElement).reset();
      }else{
        setError(result.error || "Failed to save log");
      }
      setLoading(false);

    }
  return (

    <form onSubmit={handleSubmit} className="grid grid-cols-6 gap-4 items-end">
          <input type="hidden" name="officeId" value={officeId} />
          <div className="space-y-1">
            <label className="text-xs font-bold uppercase">Date</label>
            <Input name="date" type="date" required />
          </div>
          {["powerOff", "engineOn", "powerOn", "engineOff"].map((field) => (
            <div key={field} className="space-y-1">
              <label className="text-xs font-bold uppercase">{field.replace(/([A-Z])/g, ' $1')}</label>
              <Input name={field} type="time" id={field} />
            </div>
          ))}

          <Button type="submit" disabled={loading} className="bg-blue-600 hover:bg-blue-700 w-full md:w-fit">
            {loading ? "Saving .... " : "Add Row"}
          </Button>

          {/* Show error if they exist */}
          {/* {state?.error && (
            <p className='text-red-500 text-xs'>{state.error}</p>
          )} */}
          {error && <p className="text-sm text-red-500 font-medium">{error}</p>}
        </form>
  )
}

export default EngineForm